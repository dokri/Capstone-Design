# 메인 서버 주소
MAIN_SERVER_URL=http://localhost:8000

# 이 YOLO 서버가 담당하는 카메라 ID (메인 서버에 등록된 ID와 일치해야 함)
CAMERA_ID=cam_01

# 카메라 소스
# 0          : 로컬 웹캠
# rtsp://... : IP 카메라 RTSP 스트림
# /path/to/video.mp4 : 영상 파일 (테스트용)
CAMERA_SOURCE=0

# YOLO 모델 경로 (최초 실행 시 자동 다운로드)
# yolov8n.pt : 가장 빠름 (nano)
# yolov8s.pt : 빠름 (small)
# yolov8m.pt : 중간
MODEL_PATH=yolov8n.pt

# 탐지 주기 (초) — 1.0 = 1초마다 탐지
INTERVAL=1.0

# 탐지 신뢰도 임계값 (0.0 ~ 1.0)
CONFIDENCE=0.5
